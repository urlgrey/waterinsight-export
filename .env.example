# === WaterInsight credentials ===
WATERSIGHT_EMAIL=your@email.com
WATERSIGHT_PASSWORD=your_password
WATERSIGHT_URL=https://benicia.waterinsight.com

# === InfluxDB v2 ===
INFLUXDB_URL=http://192.168.1.15:8086
INFLUXDB_TOKEN=your_influxdb_token
INFLUXDB_ORG=your_org_id
INFLUXDB_BUCKET=water_insights

# === Home Assistant via MQTT Discovery ===
# Sensors are published with retained config + state topics; they persist
# across HA restarts and appear as a single device in the HA registry.
MQTT_HOST=192.168.1.15
MQTT_PORT=1883
MQTT_USERNAME=ha
MQTT_PASSWORD=your_mqtt_password
MQTT_DISCOVERY_PREFIX=homeassistant

# === Daemon settings ===
SYNC_INTERVAL_HOURS=6
LOG_LEVEL=INFO
